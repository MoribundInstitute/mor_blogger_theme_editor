<header class='main-header'>

  <div class='header-top-row'>

    <div class='header-side-controls left-controls'>
      <button class='panel-toggle header-panel-toggle header-panel-toggle-left' data-target='panel-left' type='button'>
        {{LEFT_PANEL_OPEN_LABEL}}
      </button>
    </div>

    <a aria-label="{{SITE_TITLE_ATTR}} homepage" class='branding branding-link' href="{{SITE_HOME_URL_ATTR}}">
      <img alt="{{SITE_TITLE_ATTR}} logo" class='institute-logo' src="{{HEADER_LOGO_URL_ATTR}}"/>
      <span class='institute-title'>{{SITE_TITLE}}</span>
    </a>

    <div class='header-side-controls right-controls'>
      <button class='panel-toggle header-panel-toggle theme-toggle-btn' id='mor-theme-toggle' title='Toggle Light/Dark Mode' type='button'>
        <svg class='theme-toggle-sun' fill='currentColor' height='18' viewBox='0 0 24 24' width='18' xmlns='http://www.w3.org/2000/svg'>
          <path d='M12 7c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zm0-5c.55 0 1 .45 1 1v2c0 .55-.45 1-1 1s-1-.45-1-1V3c0-.55.45-1 1-1zm0 18c.55 0 1 .45 1 1v2c0 .55-.45 1-1 1s-1-.45-1-1v-2c0-.55.45-1 1-1zM3 11h2c.55 0 1 .45 1 1s-.45 1-1 1H3c-.55 0-1-.45-1-1s.45-1 1-1zm16 0h2c.55 0 1 .45 1 1s-.45 1-1 1h-2c-.55 0-1-.45-1-1s.45-1 1-1zM5.64 4.22l1.42 1.42c.39.39.39 1.02 0 1.41s-1.02.39-1.41 0L4.22 5.64c-.39-.39-.39-1.02 0-1.41s1.03-.4 1.42-.01zm12.02 12.02l1.42 1.42c.39.39.39 1.02 0 1.41s-1.02.39-1.41 0l-1.42-1.42c-.39-.39-.39-1.02 0-1.41s1.02-.39 1.41 0zm1.42-12.02c.39.39.39 1.02 0 1.41l-1.42 1.42c-.39.39-1.02.39-1.41 0s-.39-1.02 0-1.41l1.42-1.42c.38-.39 1.02-.39 1.41 0zM5.64 17.66c.39.39.39 1.02 0 1.41l-1.42 1.42c-.39.39-1.02.39-1.41 0s-.39-1.02 0-1.41l1.42-1.42c.39-.39 1.02-.39 1.41 0z' />
        </svg>
        <svg class='theme-toggle-moon' fill='currentColor' height='18' viewBox='0 0 24 24' width='18' xmlns='http://www.w3.org/2000/svg'>
          <path d='M12 3c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-.46-.04-.92-.1-1.36-.98 1.37-2.58 2.26-4.4 2.26-2.98 0-5.4-2.42-5.4-5.4 0-1.81.89-3.42 2.26-4.4-.44-.06-.9-.1-1.36-.1z' />
        </svg>
      </button>

      <button class='panel-toggle header-panel-toggle header-panel-toggle-right' data-target='panel-right' type='button'>
        {{RIGHT_PANEL_OPEN_LABEL}}
      </button>
    </div>

  </div>

  <div class='header-bottom-row'>
    <nav aria-label='Main navigation' class='mor-nav'>
      {{MAIN_NAV_LINKS}}
    </nav>

    <div class='mor-search'>
      <form action="{{SEARCH_ACTION_URL_ATTR}}" method='get'>
        <span class='prompt'>{{SEARCH_PROMPT}}</span>
        <input name='q' placeholder="{{SEARCH_PLACEHOLDER_ATTR}}" type='text'/>
        <button type='submit'>{{SEARCH_BUTTON_LABEL}}</button>
      </form>
    </div>
  </div>

</header>